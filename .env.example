# Copy this file to .env and fill in your credentials.

# ── Anthropic (used by the CLI audit reporter) ───────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ── Google Search Console (Phase 1 — optional) ───────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application type)
# 3. Enable the "Google Search Console API" in APIs & Services → Library
# 4. Add this exact Authorized Redirect URI:
#      http://localhost:3000/auth/google/callback
# 5. Paste your Client ID and Secret below, then restart the server.
GSC_CLIENT_ID=your_google_client_id_here
GSC_CLIENT_SECRET=your_google_client_secret_here
# GSC_REDIRECT_URI=http://localhost:3000/auth/google/callback  ← default, only change if needed
